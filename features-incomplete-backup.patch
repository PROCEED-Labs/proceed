+    });
+    if (currentFolder) wrappingFolderIds.push(currentFolder.id);
+    currentFolder = currentFolder.parentId ? await getFolderById(currentFolder.parentId) : null;
+  } while (currentFolder);
+  pathToFolder.reverse();
+  wrappingFolderIds.reverse();
+
